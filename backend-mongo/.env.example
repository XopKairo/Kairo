# Server Configuration
PORT=5000
NODE_ENV=production
APP_MODE=production

# Database
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/kairo_db

# Redis (Caching & Performance)
REDIS_URL=rediss://default:your_password@your_endpoint.upstash.io:6379

# Security
JWT_SECRET=your_jwt_secret_key
JWT_REFRESH_SECRET=your_refresh_secret

# OTP (Twilio)
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_PHONE_NUMBER=your_number

# Video Call (ZegoCloud)
ZEGO_APP_ID=your_zego_app_id
ZEGO_SERVER_SECRET=your_zego_server_secret
TURN_SECRET=your_turn_secret

# Media Upload (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Payments (Razorpay & Cashfree)
RAZORPAY_KEY_ID=your_rzp_id
RAZORPAY_KEY_SECRET=your_rzp_secret
CASHFREE_APP_ID=your_cashfree_id
CASHFREE_SECRET_KEY=your_cashfree_secret
CASHFREE_ENDPOINT=https://api.cashfree.com

# Admin Configuration
ADMIN_EMAIL=admin@zora.com
ADMIN_PASSWORD=your_secure_password
ADMIN_PHONE=+910000000000
ADMIN_URL=https://your-admin-panel.vercel.app

# Firebase (Push Notifications - Base64 encoded JSON)
FIREBASE_SERVICE_ACCOUNT=your_base64_service_account_json
